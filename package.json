{
  "name": "chat-server",
  "version": "1.0.0",
  "description": "A real-time chat server, built incrementally while learning TypeScript.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/purphoros/typescript.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/purphoros/typescript/issues"
  },
  "homepage": "https://github.com/purphoros/typescript#readme",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/ws": "^8.18.1",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vitest": "^3.2.7"
  },
  "dependencies": {
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "type": "module",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "chat-server": "dist/main.js"
  }
}
